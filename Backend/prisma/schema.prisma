generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum InterviewStatus {
  SCHEDULED
  STARTED
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  PENDING
  SUBMITTED
  EXPIRED
  REVIEWED
}


model HR {
  id             String   @id @default(uuid())
  name           String
  email          String   @unique
  companyName    String
  designation    String?
  companyWebsite String
  password       String
  createdAt      DateTime @default(now())
  plan           String   @default("free")
  interviewCount Int      @default(0)
  interviewLimit Int      @default(10)

  // Relations
  developer   Developer[]
  interviews  Interview[]
  taskLibrary TaskLibrary[]
  tasks       Task[]
}

model Developer {
  id             String   @id @default(uuid())
  hrId           String
  developerName  String
  developerEmail String
  position       String
  experience     Int
  interviewDate  DateTime
  interviewTime  String
  uniqueCode     String   @unique
  createdAt      DateTime @default(now())

  // Relations
  hr          HR           @relation(fields: [hrId], references: [id])
  interviews  Interview[]
  tasks       Task[]

}

model Interview {
  id          String          @id @default(uuid())
  hrId        String
  developerId String
  status      InterviewStatus @default(SCHEDULED)
  scheduledAt DateTime?
  createdAt   DateTime        @default(now())

  // Relations
  hr        HR        @relation(fields: [hrId], references: [id])
  developer Developer @relation(fields: [developerId], references: [id])
  task      Task?
}

model TaskLibrary {
  id           String   @id @default(uuid())
  hrId         String?
  title        String
  description  String
  requirements String
  category     String
  techStack    String
  difficulty   String
  duration     Int
  usedCount    Int      @default(0)
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())

  // Relations
  hr    HR?    @relation(fields: [hrId], references: [id])
  tasks Task[]
}

model Task {
  id            String     @id @default(uuid())
  interviewId   String     @unique
  hrId          String
  developerId   String
  taskLibraryId String
  status        TaskStatus @default(PENDING)
  deadline      DateTime
  createdAt     DateTime   @default(now())

  // Relations
  interview   Interview   @relation(fields: [interviewId], references: [id])
  hr          HR          @relation(fields: [hrId], references: [id])
  developer   Developer   @relation(fields: [developerId], references: [id])
  taskLibrary TaskLibrary @relation(fields: [taskLibraryId], references: [id])
}