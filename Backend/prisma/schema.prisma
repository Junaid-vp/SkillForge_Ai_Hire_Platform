// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum InterviewStatus {
  SCHEDULED
  STARTED
  COMPLETED
  CANCELLED
  SUSPENDED
}

enum TaskStatus {
  PENDING
  SUBMITTED
  EXPIRED
  EVALUATED
}


model HR {
  id             String   @id @default(uuid())
  name           String
  email          String   @unique
  companyName    String
  designation    String?
  companyWebsite String
  password       String
  createdAt      DateTime @default(now())
  plan           String   @default("free")
  interviewCount Int      @default(0)
  interviewLimit Int      @default(5)

  // Relations
  developer   Developer[]
  interviews  Interview[]
  taskLibrary TaskLibrary[]
  tasks       Task[]
  subscription Subscription?
  interviewNotes InterviewNote[]
  notifications  Notification[]
  
  // Notification Preferences
  notifInterviews  Boolean  @default(true)
  notifSubmissions Boolean  @default(true)
  notifProgress    Boolean  @default(true)
}

model Developer {
  id             String   @id @default(uuid())
  hrId           String
  developerName  String
  developerEmail String
  position       String
  experience     Int
  interviewDate  DateTime
  interviewTime  String
  uniqueCode     String   @unique
  createdAt      DateTime @default(now())

  
  resumeUrl      String?  
  skills         String? 
  aiSummary      String? 

  hr          HR          @relation(fields: [hrId], references: [id])
  interviews  Interview[]
  tasks       Task[]
}

model Interview {
  id                   String          @id @default(uuid())
  hrId                 String
  developerId          String
  status               InterviewStatus @default(SCHEDULED)
  scheduledAt          DateTime?
  createdAt            DateTime        @default(now())
  feedback             Json?
    feedbackGeneratedAt  DateTime?
    reportSent           Boolean         @default(false)
    reminder10Sent       Boolean         @default(false)
  // Relations
  hr        HR        @relation(fields: [hrId], references: [id])
  developer Developer @relation(fields: [developerId], references: [id])
  task      Task?
  questions   Question[]
  answers     Answer[]
  note        InterviewNote?
  codeAnswers CodeAnswer[] 
}

model TaskLibrary {
  id           String   @id @default(uuid())
  hrId         String?
  title        String
  description  String
  requirements Json
  category     String
  techStack    String
  difficulty   String
  duration     Int
  usedCount    Int      @default(0)
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())

  // Relations
  hr    HR?    @relation(fields: [hrId], references: [id])
  tasks Task[]
}

model Task {
  id            String     @id @default(uuid())
  interviewId   String     @unique
  hrId          String
  developerId   String
  taskLibraryId String
  status        TaskStatus @default(PENDING)
  deadline      DateTime
  createdAt     DateTime   @default(now())

  
  submissionUrl String?    // ZIP file URL
  submittedAt   DateTime?  // when submitted
  aiReport      Json?        //store full AI response
  aiScore       Int?       // overall score

  interview   Interview   @relation(fields: [interviewId], references: [id])
  hr          HR          @relation(fields: [hrId], references: [id])
  developer   Developer   @relation(fields: [developerId], references: [id])
  taskLibrary TaskLibrary @relation(fields: [taskLibraryId], references: [id])
}



model Subscription {
  id               String    @id @default(uuid())
  hrId             String    @unique
  plan             String    @default("free")
  stripeCustomerId String?
  stripeSubId      String?
  status           String    @default("active")
  currentPeriodEnd DateTime?
  createdAt        DateTime  @default(now())

  hr               HR        @relation(fields: [hrId], references: [id])
}


model Question {
  id             String   @id @default(uuid())
  interviewId    String
  questionText   String
  expectedAnswer String
  keywords       String
  difficulty     String
  orderIndex     Int
  isLeetcode     Boolean  @default(false)
  
 
  estimatedTime  Int?     // AI estimated minutes (10, 20, 30)
  inputExample   String?  // example input
  outputExample  String?  // expected output
  constraints    String?  // problem constraints
  
  createdAt      DateTime @default(now())

  interview      Interview  @relation(fields: [interviewId], references: [id])
  answer         Answer?
  codeAnswer     CodeAnswer? // ← add this
}


model CodeAnswer {
  id          String   @id @default(uuid())
  questionId  String   @unique
  interviewId String
  code        String
  language    String
  output      String?
  codeStatus  String?
  runCount    Int      @default(0)
  submittedAt DateTime @default(now())

  question    Question  @relation(fields: [questionId], references: [id])
  interview   Interview @relation(fields: [interviewId], references: [id])
}

model Answer {
  id          String   @id @default(uuid())
  questionId  String   @unique
  interviewId String
  answerText  String
  score       Int?
  feedback    String?
  status      String   @default("PENDING")
  submittedAt DateTime @default(now())

  question    Question  @relation(fields: [questionId], references: [id])
  interview   Interview @relation(fields: [interviewId], references: [id])
}

model InterviewNote {
  id          String   @id @default(uuid())
  interviewId String   @unique
  hrId        String
  content     String
  updatedAt   DateTime @updatedAt

  interview   Interview @relation(fields: [interviewId], references: [id])
  hr          HR        @relation(fields: [hrId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  hrId      String
  title     String
  message   String
  type      String   // e.g., "INTERVIEW", "TASK", "SYSTEM"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  hr HR @relation(fields: [hrId], references: [id])
}